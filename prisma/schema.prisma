datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  workspaces   Workspace[]
}

model Workspace {
  id               String            @id @default(uuid())
  name             String
  ownerId          String
  owner            User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  whatsappAccounts WhatsAppAccount[]
  contacts         Contact[]
  automationRules  AutomationRule[]
  messageLogs      MessageLog[]
}

model WhatsAppAccount {
  id                          String    @id @default(uuid())
  workspaceId                 String
  workspace                   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  phone_number_id             String    @unique
  whatsapp_business_account_id String
  access_token                String    // Decrypted or secured system user token
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
}

model Contact {
  id          String    @id @default(uuid())
  phone       String    // E.g., "15550199999" (without + prefix for Meta compatibility)
  name        String?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, phone])
}

model AutomationRule {
  id             String    @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  triggerKeyword String    // Keyword to match, e.g., "support", "pricing"
  replyText      String?   // Markdown/Text to send back
  templateId     String?   // Optional template name/id
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([workspaceId, triggerKeyword])
}

model MessageLog {
  id             String    @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  phone_number_id String
  direction      String    // INBOUND or OUTBOUND
  senderPhone    String
  recipientPhone String
  messageText    String?
  status         String    // SENT, DELIVERED, READ, FAILED
  metadata       Json?     // Meta webhook payload ID, error logs, etc.
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([workspaceId, phone_number_id])
}
